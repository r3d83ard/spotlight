%
O1000 (MAIN PROGRAM)
N10 G90 G54 G00 X0. Y0. Z0. ; ABSOLUTE RAPID
N20 M03 S1200
N30 #1 = 2
N40 #500 = [#1 + 5]
N50 #<DEPTH> = -0.125
N60 IF [#500 GT 6] THEN #3006 = 1 (CHECK VARIABLE)
N65 IF [#500 LT 3] GOTO 110
N70 M98 P1234
N80 G65 P9001 A1. B2. C3.
N90 G66 P9001 X1. Y2.
N100 G66.1 P9001
N110 M30
%

%
O1234 (((SUB PROGRAM)))
N10 G01 Z[#<DEPTH>] F25.
N20 #2 = #[#1 + 3]
N30 WHILE [#2 LT 10] DO1
N40 #2 = [#2 + 1]
N50 END1
N60 M99
%

%
O9001 (SUB MACRO)
N10 G01 X[10.0 + #1] Y[5.0 - #2]
N20 M99
%
